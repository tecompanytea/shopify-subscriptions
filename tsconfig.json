{
  "include": [
    "env.d.ts",
    "app/**/*",
    "test/**/*",
    "extensions/**/*",
    "config/**/*",
    "type-definitions/global.d.ts",
    "type-definitions/index.d.ts",
    ".react-router/types/**/*"
  ],
  "exclude": ["build", "public", "node_modules/**/*", "extensions/*"],
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "isolatedModules": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "target": "ES2022",
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "noImplicitAny": false,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["./app/*"],
      "#/*": ["./test/*"]
    },
    "types": [
      "@shopify/app-bridge-types",
      "@shopify/polaris-types",
      "@react-router/node",
      "vitest/globals"
    ],
    "rootDirs": [".", "./.react-router/types"],
    "noEmit": true,
    "skipLibCheck": true
  }
}
